							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "AzureSqlSource",
									"sqlReaderQuery": {
										"value": "\nWITH HeaderValidationStatus AS (\n    SELECT \n        r.Batch_Id,\n        r.Invoice_Number,\n        r.Source,\n        r.Supplier_Number,\n        r.Invoice_Amount,\n        SUM(r.Line_Amount) AS Total_Line_Amount,\n        \n        CASE \n            WHEN r.Source IS NULL OR r.Source = '' OR UPPER(r.Source) <> 'CAMSIS' THEN 0\n            WHEN r.Invoice_Number IS NULL OR r.Invoice_Number = '' THEN 0\n            WHEN r.Invoice_Amount IS NULL THEN 0\n            WHEN r.Invoice_Date IS NULL OR r.Invoice_Date = '' THEN 0\n            WHEN r.Supplier_Number IS NULL OR r.Supplier_Number = '' THEN 0\n            WHEN NOT EXISTS (\n                SELECT 1 FROM dbo.tb_supplier_details s \n                WHERE CAST(s.SUPPLIER_NUMBER AS NVARCHAR(100)) = CAST(r.Supplier_Number AS NVARCHAR(100))\n            ) THEN 0\n            WHEN NOT EXISTS (\n                SELECT 1 FROM dbo.tb_supplier_details s \n                WHERE CAST(s.SUPPLIER_NUMBER AS NVARCHAR(100)) = CAST(r.Supplier_Number AS NVARCHAR(100))\n                AND s.BUSINESS_UNIT_NAME = 'Academic University'\n            ) THEN 0\n            WHEN EXISTS (\n                SELECT 1 FROM dbo.tb_ap_invoices_staging stg \n                WHERE stg.SupplierNumber = r.Supplier_Number \n                AND stg.InvoiceNumber = r.Invoice_Number\n                AND UPPER(stg.Source) = UPPER(r.Source)\n                AND stg.BatchId <> r.Batch_Id  -- Exclude current batch\n            ) THEN 0\n            ELSE 1\n        END AS Header_Valid\n        \n    FROM dbo.tb_ap_invoices_raw r\n    GROUP BY \n        r.Batch_Id,\n        r.Invoice_Number,\n        r.Source,\n        r.Supplier_Number,\n        r.Invoice_Amount,\n        r.Invoice_Date\n),\nHeaderWithAmountCheck AS (\n    SELECT \n        hvs.*,\n        CASE \n            WHEN hvs.Header_Valid = 1 AND hvs.Invoice_Amount = hvs.Total_Line_Amount THEN 'Validation Success'\n            ELSE 'Validation Failed'\n        END AS Header_Validation_Status\n    FROM HeaderValidationStatus hvs\n)\n\nSELECT \n    r.Id,\n    r.Batch_Id,\n    r.Source,\n    r.Invoice_Number,\n    r.Line_Number,\n    r.Line_Amount,\n    'ITEM' AS Line_Type,\n    r.Line_Description,\n    r.Distribution_Combination,\n    r.Project_Number,\n    r.Task,\n    r.Expenditure_Type,\n    r.Expenditure_Organization,\n    r.Award,\n    r.Metadata_Unique_Identifier,\n    'OOS' AS Tax_Classification_Code,\n    h.Header_Validation_Status AS Validation_Status,\n    CASE \n        WHEN h.Header_Validation_Status = 'Validation Failed' \n        THEN 'Header validation failed - all lines rejected'\n        ELSE NULL\n    END AS Validation_Error,\n    0 AS Processed_Bit,\n    NULL AS Processed_At\n\nFROM dbo.tb_ap_invoices_raw r\nINNER JOIN HeaderWithAmountCheck h \n    ON r.Batch_Id = h.Batch_Id \n    AND r.Invoice_Number = h.Invoice_Number\nORDER BY \n    r.Batch_Id,\n    r.Invoice_Number,\n    r.Line_Number;",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"sink": {
									"type": "AzureSqlSink",
									"writeBehavior": "insert",
									"sqlWriterUseTableLock": false
								},
								"enableStaging": false,
								"translator": {
