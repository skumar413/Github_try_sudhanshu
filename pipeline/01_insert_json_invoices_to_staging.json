							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "AzureSqlSource",
									"sqlReaderQuery": {
										"value": "@concat('\nWITH InvoiceHeaderValidation AS (\n    SELECT \n        r.Batch_Id,\n        r.Source,\n        r.Supplier_Name,\n        r.Supplier_Number,\n        r.Supplier_Identifier,\n        r.Invoice_Number,\n        r.Invoice_Date,\n        r.Invoice_Amount,\n        r.Invoice_Currency,\n        r.Header_Description,\n        r.Metadata_Unique_Identifier,\n        \n        SUM(r.Line_Amount) AS Total_Line_Amount,\n        COUNT(*) AS Line_Count,\n        \n        s.BUSINESS_UNIT_NAME AS Business_Unit,\n        ''STANDARD'' AS Invoice_Type,\n        ''BACS'' AS Payment_Method,\n        r.Invoice_Currency AS Payment_Currency,\n        ''OOS'' AS Tax_Classification_Code,\n        s.TERMS_NAME AS Payment_Terms,\n        s.VENDOR_SITE_CODE AS Supplier_Site,\n        \n        CASE \n            WHEN TRY_CAST(r.Invoice_Date AS DATE) BETWEEN ''', variables('start_date'), ''' AND ''', variables('end_date'), '''\n            THEN FORMAT(TRY_CAST(r.Invoice_Date AS DATE), ''yyyy/MM/dd'')\n            ELSE FORMAT(GETDATE(), ''yyyy/MM/dd'')\n        END AS Accounting_Date,\n        \n        CASE WHEN r.Source IS NULL OR r.Source = '''' THEN 0 ELSE 1 END AS Valid_Source,\n        CASE WHEN r.Source = ''CamSIS'' THEN 1 ELSE 0 END AS Valid_Source_Value,\n        CASE WHEN r.Invoice_Number IS NULL OR r.Invoice_Number = '''' THEN 0 ELSE 1 END AS Valid_Invoice_Number,\n        CASE WHEN r.Invoice_Amount IS NULL THEN 0 ELSE 1 END AS Valid_Invoice_Amount,\n        CASE WHEN r.Invoice_Date IS NULL OR r.Invoice_Date = '''' THEN 0 ELSE 1 END AS Valid_Invoice_Date,\n        CASE WHEN r.Supplier_Number IS NULL OR r.Supplier_Number = '''' THEN 0 ELSE 1 END AS Valid_Supplier_Number,\n        CASE WHEN s.SUPPLIER_NUMBER IS NOT NULL THEN 1 ELSE 0 END AS Valid_Supplier_Exists,\n        CASE WHEN s.BUSINESS_UNIT_NAME = ''Academic University'' THEN 1 ELSE 0 END AS Valid_Business_Unit,\n        CASE WHEN NOT EXISTS (\n            SELECT 1 FROM dbo.tb_ap_invoices_staging stg \n            WHERE stg.SupplierNumber = r.Supplier_Number \n            AND stg.InvoiceNumber = r.Invoice_Number\n            AND stg.Source = r.Source\n        ) THEN 1 ELSE 0 END AS Valid_Unique_Invoice\n        \n    FROM dbo.tb_ap_invoices_raw r\n    LEFT JOIN dbo.tb_supplier_details s \n        ON CAST(r.Supplier_Number AS NVARCHAR(100)) = CAST(s.SUPPLIER_NUMBER AS NVARCHAR(100))\n    GROUP BY \n        r.Batch_Id,\n        r.Source,\n        r.Supplier_Name,\n        r.Supplier_Number,\n        r.Supplier_Identifier,\n        r.Invoice_Number,\n        r.Invoice_Date,\n        r.Invoice_Amount,\n        r.Invoice_Currency,\n        r.Header_Description,\n        r.Metadata_Unique_Identifier,\n        s.TERMS_NAME,\n        s.VENDOR_SITE_CODE,\n        s.SUPPLIER_NUMBER,\n        s.BUSINESS_UNIT_NAME\n)\n\nSELECT \n    hv.Batch_Id,\n    hv.Source,\n    hv.Supplier_Name,\n    hv.Supplier_Number,\n    hv.Supplier_Identifier,\n    hv.Invoice_Number,\n    hv.Invoice_Date,\n    hv.Invoice_Amount,\n    hv.Invoice_Currency,\n    hv.Header_Description,\n    hv.Payment_Currency,\n    hv.Business_Unit,\n    hv.Invoice_Type,\n    hv.Payment_Method,\n    hv.Payment_Terms,\n    hv.Supplier_Site,\n    hv.Accounting_Date,\n    hv.Tax_Classification_Code,\n    hv.Metadata_Unique_Identifier,\n    hv.Total_Line_Amount,\n    hv.Line_Count,\n    CASE WHEN hv.Invoice_Amount = hv.Total_Line_Amount THEN 1 ELSE 0 END AS Valid_Amount_Balance,\n    CASE \n        WHEN hv.Valid_Source = 1\n            AND hv.Valid_Source_Value = 1\n            AND hv.Valid_Invoice_Number = 1\n            AND hv.Valid_Invoice_Amount = 1\n            AND hv.Valid_Invoice_Date = 1\n            AND hv.Valid_Supplier_Number = 1\n            AND hv.Valid_Supplier_Exists = 1\n            AND hv.Valid_Business_Unit = 1\n            AND hv.Valid_Unique_Invoice = 1\n            AND hv.Invoice_Amount = hv.Total_Line_Amount\n        THEN ''Validation Success''\n        ELSE ''Validation Failed''\n    END AS Validation_Status,\n    CASE \n        WHEN hv.Valid_Source = 0 THEN ''BR2: Source is required''\n        WHEN hv.Valid_Source_Value = 0 THEN ''BR2: Source must be CamSIS''\n        WHEN hv.Valid_Invoice_Number = 0 THEN ''BR2: Invoice Number is required''\n        WHEN hv.Valid_Invoice_Amount = 0 THEN ''BR2: Invoice Amount is required''\n        WHEN hv.Valid_Invoice_Date = 0 THEN ''BR2: Invoice Date is required''\n        WHEN hv.Valid_Supplier_Number = 0 THEN ''BR2/BR7: Supplier Number is required''\n        WHEN hv.Valid_Supplier_Exists = 0 THEN ''BR7: Supplier Number not found in Oracle''\n        WHEN hv.Valid_Business_Unit = 0 THEN ''BR1: Supplier Business Unit must be Academic University''\n        WHEN hv.Valid_Unique_Invoice = 0 THEN ''BR4: Duplicate Invoice (Supplier + Invoice Number exists)''\n        WHEN hv.Invoice_Amount <> hv.Total_Line_Amount THEN ''BR2: Invoice Amount does not match sum of Line Amounts''\n        ELSE NULL\n    END AS Validation_Error,\n    0 AS Processed_Bit,\n    NULL AS Processed_At,\n    GETDATE() AS Invoice_Received_Date\nFROM InvoiceHeaderValidation hv;\n')",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
